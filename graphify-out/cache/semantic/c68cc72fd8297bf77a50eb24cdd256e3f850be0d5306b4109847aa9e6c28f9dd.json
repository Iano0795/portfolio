{"nodes": [{"id": "writeups_manager_complete_writeups_manager", "label": "Writeups Manager (Task 27)", "file_type": "concept", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Built as CRUD foundation first; request-access workflow, file upload UI, and public display intentionally deferred to Task 28 to keep scope focused."}, {"id": "writeups_manager_complete_lab_writeups_table", "label": "lab_writeups Table", "file_type": "concept", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "writeups_manager_complete_three_level_visibility", "label": "Three-Level Visibility System", "file_type": "rationale", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Public (full content, safe retired machines), Restricted (teaser only, requires approval, the default for most writeups), Private (not shown, for active machines and drafts) balances sharing educational content against spoiling challenges."}, {"id": "writeups_manager_complete_machine_status_safety", "label": "Machine Status Safety Rule", "file_type": "rationale", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Active machines cannot have public visibility, enforced in both server validation and UI warnings, to prevent spoiling currently-available lab challenges."}, {"id": "writeups_manager_complete_stable_id_array_fields", "label": "Array Fields with Stable UUID IDs", "file_type": "rationale", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Using editable string values as React keys causes inputs to lose focus when typing; each EditableListItem carries a stable UUID id used as the React key, separate from the editable value, so focus is preserved."}, {"id": "writeups_manager_complete_portfolio_scoping", "label": "Portfolio-Scoped Isolation", "file_type": "rationale", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never trust the client: portfolioSlug comes from route params, the server resolves it to portfolio_id via database lookup, all queries use the server-resolved id, and RLS enforces database-level isolation so cross-portfolio access is impossible."}, {"id": "writeups_manager_complete_role_permissions", "label": "Role-Based Permissions (Owner/Admin/Editor/Viewer)", "file_type": "concept", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Manager roles (owner/admin/editor) get full CRUD; viewer role is read-only; enforced both client-side (disabled UI) and server-side (requirePortfolioManager throws for viewers)."}, {"id": "writeups_manager_complete_rls_policies", "label": "Writeups RLS Policies", "file_type": "concept", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "writeups_manager_complete_requireportfolioaccess", "label": "requirePortfolioAccess()", "file_type": "concept", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "writeups_manager_complete_requireportfoliomanager", "label": "requirePortfolioManager()", "file_type": "concept", "source_file": "WRITEUPS_MANAGER_COMPLETE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributo