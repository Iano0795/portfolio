{"nodes": [{"id": "docs_writeups_and_labs_consolidation_writeups_and_labs_consolidation", "label": "Writeups & Labs Consolidation", "file_type": "concept", "source_file": "Docs/writeups-and-labs-consolidation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Violet's public portfolio no longer renders a separate Projects section; her cybersecurity lab cards move into a unified Writeups & Labs section backed by lab_writeups. The shared projects table and Projects Manager remain for Ian and other portfolios; Violet's old project rows are archived only after being copied into lab_writeups."}, {"id": "docs_writeups_and_labs_consolidation_lab_type", "label": "Lab Type Classification", "file_type": "concept", "source_file": "Docs/writeups-and-labs-consolidation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "lab_type is offensive or defensive; Violet's public filters combine lab type with machine status (All/Offensive/Defensive crossed with All/Active/Retired)."}, {"id": "docs_writeups_and_labs_consolidation_is_requestable", "label": "is_requestable Flag", "file_type": "concept", "source_file": "Docs/writeups-and-labs-consolidation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Requestability is an explicit flag rather than implied by visibility: restricted labs accept requests only when true. Active labs are not automatically rejected but default to false, and admins see a warning to approve active-lab access only where platform rules permit solution sharing."}, {"id": "docs_writeups_and_labs_consolidation_content_markdown", "label": "content_markdown Field", "file_type": "concept", "source_file": "Docs/writeups-and-labs-consolidation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": 