{"nodes": [{"id": "docs_restricted_writeups_foundation_restricted_writeup_access_system", "label": "Restricted Writeup Access System", "file_type": "concept", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Lab writeups are kept separate from Projects because writeups contain sensitive detailed methodology needing flexible access control (public/restricted/private), while projects are always-safe public showcase cards. A writeup can optionally reference a project via project_id to link detailed content to its portfolio card."}, {"id": "docs_restricted_writeups_foundation_lab_writeups", "label": "lab_writeups Table", "file_type": "concept", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_restricted_writeups_foundation_writeup_access_requests", "label": "writeup_access_requests Table", "file_type": "concept", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_restricted_writeups_foundation_writeup_access_grants", "label": "writeup_access_grants Table", "file_type": "concept", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stores only token_hash (SHA-256), never raw tokens, plus expiry, view limits, and revocation fields so access can be time-limited, view-limited, and revoked per grant."}, {"id": "docs_restricted_writeups_foundation_writeup_access_logs", "label": "writeup_access_logs Table", "file_type": "concept", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Audit trail of all access-related events (request_created, request_approved, grant_created, grant_viewed, grant_revoked, access_denied, etc.) for compliance and security auditing."}, {"id": "docs_restricted_writeups_foundation_token_utilities", "label": "Server-Side Token Utilities", "file_type": "concept", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Token-based access was chosen over email-only access (no audit trail or revocation), shared passwords (leak), and required accounts (friction): tokens are revocable per-recipient, time/view limited, fully audit-trailed, and need no user account. Tokens are 32-byte cryptographically random values, hashed with SHA-256 before storage, verified with timing-safe comparison, and the utilities must never be exposed to client components."}, {"id": "docs_restricted_writeups_foundation_visibility_levels", "label": "Writeup Visibility Levels", "file_type": "concept", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "public = direct access for safe retired content; restricted = teaser plus request/approval/token flow for most writeups; private = portfolio members only for active machines and drafts."}, {"id": "docs_restricted_writeups_foundation_machine_status", "label": "Machine Status", "file_type": "concept", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_restricted_writeups_foundation_private_storage_signed_urls", "label": "Private Storage with Signed URLs", "file_type": "rationale", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Public storage risks URL guessing/enumeration with no access control or usage tracking. The private writeups bucket with server-generated short-lived (15-60 min) signed URLs gives revocable, logged, token-validated access to restricted files."}, {"id": "docs_restricted_writeups_foundation_active_machine_protection", "label": "Active Machine Protection", "file_type": "rationale", "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Writeups for active (unretired) challenges must never be public to avoid spoiling live machines; active machines default to restricted or private and the system blocks the active + public combination via server validation and RPC filters."}], "edges": [{"source": "docs_restricted_writeups_foundation_restricted_writeup_access_system", "target": "docs_restricted_writeups_foundation_lab_writeups", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}, {"source": "docs_restricted_writeups_foundation_restricted_writeup_access_system", "target": "docs_restricted_writeups_foundation_writeup_access_requests", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}, {"source": "docs_restricted_writeups_foundation_restricted_writeup_access_system", "target": "docs_restricted_writeups_foundation_writeup_access_grants", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}, {"source": "docs_restricted_writeups_foundation_restricted_writeup_access_system", "target": "docs_restricted_writeups_foundation_writeup_access_logs", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}, {"source": "docs_restricted_writeups_foundation_token_utilities", "target": "docs_restricted_writeups_foundation_writeup_access_grants", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}, {"source": "docs_restricted_writeups_foundation_private_storage_signed_urls", "target": "docs_restricted_writeups_foundation_restricted_writeup_access_system", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}, {"source": "docs_restricted_writeups_foundation_active_machine_protection", "target": "docs_restricted_writeups_foundation_visibility_levels", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}, {"source": "docs_restricted_writeups_foundation_visibility_levels", "target": "docs_restricted_writeups_foundation_machine_status", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}, {"source": "docs_restricted_writeups_foundation_lab_writeups", "target": "docs_restricted_writeups_foundation_visibility_levels", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/restricted-writeups-foundation.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "writeup_access_data_model", "label": "Writeup Access Data Model", "nodes": ["docs_restricted_writeups_foundation_lab_writeups", "docs_restricted_writeups_foundation_writeup_access_requests", "docs_restricted_write